# Copy to .env and fill in your values. NEVER commit the real .env.

APP_ENV=local
DATA_INPUT_GLOB=data/raw/*

DEFAULT_COUNTRY=CA
DEFAULT_LANGUAGE=en
# Safety default: no real emails are sent unless you explicitly set false.
DRY_RUN=true

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your_email@example.com
# Use an app password (Google Account -> Security -> App passwords).
SMTP_PASSWORD=change_me
SMTP_FROM_EMAIL=your_email@example.com
SMTP_FROM_NAME=Your Name
SENDER_PHONE=
REPLY_TO=
ATTACHMENT_PATH=/absolute/path/to/your/cv.pdf

SEND_RATE_SECONDS=3
MAX_EMAILS_PER_RUN=20

ALLOWED_RECIPIENT_DOMAINS=
BLOCKED_RECIPIENT_DOMAINS=gmail.com,yahoo.com,hotmail.com,outlook.com

SEND_HISTORY_PATH=logs/send_history.csv
LEARNING_FEEDBACK_PATH=logs/learning_feedback.csv
MAX_ATTEMPTS_PER_PERSON=3
MAX_RETRIES_SAME_SOFT_BOUNCE=2

IMAP_HOST=imap.gmail.com
IMAP_USERNAME=your_email@example.com
IMAP_PASSWORD=change_me
